{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "final-project",
  "compatibility_date": "2025-01-29",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "dev": {
    "ip": "127.0.0.1",
    "port": 3000,
    "local_protocol": "http"
  },
  "placement": {
    "mode": "smart"
  },
  "pages_build_output_dir": ".vercel/output/static",
  "observability": {
    "enabled": true
  }
}